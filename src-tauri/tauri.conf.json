{
  "$schema": "https://raw.githubusercontent.com/nicedoc/schema/master/tauri-conf-v2.json",
  "productName": "My Claude",
  "version": "0.1.0",
  "identifier": "cc.imre.myclaude",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:3019",
    "beforeBuildCommand": "pnpm build && node scripts/copy-server.mjs"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self' http://localhost:3019; script-src 'self' 'unsafe-inline' 'unsafe-eval' http://localhost:3019; style-src 'self' 'unsafe-inline' http://localhost:3019; connect-src http://localhost:3019; img-src 'self' data: http://localhost:3019; font-src 'self' data: http://localhost:3019"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "signingIdentity": "-"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "resources": {
      "server": "server"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIyNTRFMTIzNTJFNTNEREUKUldUZVBlVlNJK0ZVc3V3VFFtOGVUaURvZldieVdWNDh6Q1RrQ2M4SGlDNlZRNGZ5dUFkcWpJTVoK",
      "endpoints": [
        "https://github.com/imre-software/myclaude/releases/latest/download/latest.json"
      ]
    }
  }
}
